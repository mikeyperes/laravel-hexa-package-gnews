{
    "name": "hexawebsystems/laravel-hexa-package-gnews",
    "description": "GNews — article and news API integration for headline fetching, topic search, and content sourcing.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_gnews\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_gnews\\Providers\\GNewsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
